{
  "name": "kinestilistas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rimraf .next && next dev --webpack",
    "dev:clean": "rimraf .next && rimraf node_modules/.cache && next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "build:clean": "rimraf .next && next build --webpack",
    "start:clean": "rimraf .next && next build --webpack && next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "quality:react-doctor": "npx -y react-doctor@latest app --verbose --no-score",
    "quality:wave": "node ./scripts/wave-audit.mjs",
    "quality:ui": "npm run quality:react-doctor && npm run quality:wave",
    "business:route-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/business-route-smoke.ts",
    "business:critical-smoke": "node ./scripts/business-critical-smoke.mjs",
    "m1-m3:closeout": "cross-env CLIENT_DEBUG=false TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m1-m3-closeout-smoke.ts",
    "m4:closeout": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m4-closeout-smoke.ts",
    "m4:partial-payment-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m4-partial-payment-smoke.ts",
    "m4:ui-check": "node ./scripts/m4-ui-headless-check.mjs",
    "m5:technical-email-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m5-technical-email-smoke.ts",
    "m5:service-templates-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m5-service-templates-smoke.ts",
    "m5:salon-visual-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m5-salon-visual-results-smoke.ts",
    "m6:communications-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m6-communications-smoke.ts",
    "m6:promotion-discount-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m6-promotion-discount-smoke.ts",
    "m6:client-tier-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m6-client-tier-smoke.ts",
    "m6:closeout": "npm run m6:communications-smoke && npm run m6:promotion-discount-smoke && npm run m6:client-tier-smoke",
    "m7:integrations-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-integrations-smoke.ts",
    "m7:support-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-support-smoke.ts",
    "m7:operations-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-operations-smoke.ts",
    "m7:audit-export-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-audit-export-smoke.ts",
    "m7:rate-limit-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-rate-limit-smoke.ts",
    "m7:operations-report-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-operations-report-smoke.ts",
    "m7:enterprise-operations-smoke": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/m7-enterprise-operations-smoke.ts",
    "m7:closeout": "npm run m7:integrations-smoke && npm run m7:support-smoke && npm run m7:operations-smoke && npm run m7:audit-export-smoke && npm run m7:rate-limit-smoke && npm run m7:operations-report-smoke && npm run m7:enterprise-operations-smoke",
    "catalog:upload-product-images": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ./scripts/load-env.cjs -r ts-node/register -r tsconfig-paths/register ./scripts/upload-product-images.ts",
    "db:backup-data": "node ./scripts/backup-data-only.mjs",
    "db:restore-data": "node ./scripts/restore-data-only.mjs",
    "db:prepare-demo": "node ./scripts/prepare-demo-data.mjs",
    "typeorm:cli": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:ds": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./lib/typeorm/data-source-cli.ts",
    "migration:create": "cross-env TS_NODE_PROJECT=./tsconfig.typeorm.json npm run typeorm:cli -- migration:create",
    "migration:generate": "npm run typeorm:ds -- migration:generate",
    "migration:run": "npm run typeorm:ds -- migration:run",
    "migration:revert": "npm run typeorm:ds -- migration:revert",
    "migration:show": "npm run typeorm:ds -- migration:show"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.28",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5"
  }
}
